#@ Enable WenWen Automatic Speech Recognition
CONFIG_WENWEN_ASR=y
#@ WenWen ASR only need one mic data
CONFIG_WENWEN_ASR_VERSION_SINGLE_MIC=y
#@ Enable Audio Record
CONFIG_AUDIO_RECORD=y
#@ CPU0 RAM size for SPE
CONFIG_CPU0_SPE_RAM_SIZE=0X48800
#@ CPU1 app RAM size
CONFIG_CPU1_APP_RAM_SIZE=0X57800
CONFIG_PSRAM_APS128XXO_OB9=y
#@ when initialising psram memory,its contents are
CONFIG_PSRAM_HEAP_INIT_SET_ZERO=y
