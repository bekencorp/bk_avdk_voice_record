#@ Enable Override Flash Partition
CONFIG_OVERRIDE_FLASH_PARTITION=y
#@ Enable Agora iot sdk lib
CONFIG_AGORA_IOT_SDK=y
#@ Enable FreeRTOS Posix
CONFIG_FREERTOS_POSIX=y
#@ Use an external 32k crystal
CONFIG_EXTERN_32K=n
#@ 32k use the 26m divide
CONFIG_LPO_SRC_26M32K=y
#@ CPU frequency
CONFIG_CPU_FREQ_HZ=240000000
#@ Task Watchdog Period(ms)
CONFIG_TASK_WDT_PERIOD_MS=2400000
#@ Set transfer app task size
CONFIG_TRANS_APP_TASK_SIZE=10240
#@ CPU0 RAM size for SPE
CONFIG_CPU0_SPE_RAM_SIZE=0X46000
#@ CPU1 app RAM size
CONFIG_CPU1_APP_RAM_SIZE=0X4F000
#@ CPU2 app RAM size
CONFIG_CPU2_APP_RAM_SIZE=0XB000
#@ 0
CONFIG_DMA_LOGIC_CHAN_ID_MIN=0
#@ Enable PSRAM write through
CONFIG_PSRAM_WRITE_THROUGH=y
#@ The psram address is from 0x60000000 to 0x60800000 for psram aps6408l_o
CONFIG_PSRAM_HEAP_BASE=0x60B00000
#@ psram aps6408l-o
CONFIG_PSRAM_HEAP_SIZE=0x200000
#@ Set psram_malloc base address
CONFIG_PSRAM_HEAP_CPU0_BASE_ADDER=0x60B00000
#@ Enable USB
CONFIG_USB=n
CONFIG_MENTOR_USB=n
#@ CHERRY_USB
CONFIG_CHERRY_USB=n
#@ Enable USB Host Mode
CONFIG_USB_HOST=n
#@ Enable USB Device Mode
CONFIG_USB_DEVICE=n
#@ Priority of USB task
CONFIG_TASK_USB_PRIO=5
#@ Enable Usb Uvc
CONFIG_USB_UVC=n
#@ Enable Usb Uac
CONFIG_USB_UAC=n
#@ Enable Usb Uac Mic
CONFIG_USB_UAC_MIC=n
#@ Enable Usb Uac Speaker
CONFIG_USB_UAC_SPEAKER=n
CONFIG_UVC_UAC_DEMO=n
CONFIG_UVC_UAC_DEMO_DEBUG=n
#@ Enable Multi-core operation USB
CONFIG_USB_MAILBOX=n
#@ Enable USB mailbox master
CONFIG_USB_MAILBOX_MASTER=n
#@ Enable USB mailbox slave
CONFIG_USB_MAILBOX_SLAVE=n
#@ Support FATFS
CONFIG_FATFS=n
#@ Enable Wifi Fast DHCP with easy flash
CONFIG_EASY_FLASH_FAST_DHCP=n
#@ Enable sta use static ip
CONFIG_STA_USE_STATIC_IP=n
#@ Set the size of the heap memory. The recommended value is 51200 .
CONFIG_LWIP_MEM_SIZE=92160
#@ Set the size of the max memory rx used. The recommended value is
CONFIG_LWIP_MEM_MAX_RX_SIZE=15360
#@ Set the size of the max memory tx used. The recommended value is
CONFIG_LWIP_MEM_MAX_TX_SIZE=76800
#@ Cpu1 core offset address default 0x2e0000
CONFIG_SYS_CPU1_OFFSET=0x2220000
