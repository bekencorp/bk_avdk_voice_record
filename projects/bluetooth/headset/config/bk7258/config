#@ System CPU count: 1: single core, 2: dual core, etc.
CONFIG_CPU_CNT=2
#@ CPU0 system
CONFIG_SYS_CPU0=y
#@ Enable mail_box
CONFIG_MAILBOX=y
#@ Enable Shell and Async log optimize
CONFIG_SHELL_ASYNCLOG=y
#@ Enable Memory Protect Unit Feature
CONFIG_MPU=y
#@ Enable Cache
CONFIG_CACHE_ENABLE=y
#@ When this option is enable, more memory will be consumed because
CONFIG_MEM_DEBUG=y
#@ Enable Flash Size 4M
CONFIG_FLASH_SIZE_4M=y
#@ Enable psram_malloc API
CONFIG_PSRAM_AS_SYS_MEMORY=y
#@ The psram address is from 0x60000000 to 0x60800000 for psram aps6408l_o
CONFIG_PSRAM_HEAP_BASE=0x60700000
#@ psram aps6408l-o
CONFIG_PSRAM_HEAP_SIZE=0x80000
CONFIG_CPU_WITHOUT_BOOTLOADER=y
#@ Use tickless idle, can be 0/1/2
CONFIG_FREERTOS_USE_TICKLESS_IDLE=2
#@ CPU frequency
CONFIG_CPU_FREQ_HZ=120000000
#@ 26000000
CONFIG_XTAL_FREQ=26000000
CONFIG_AON_MPU_REG_DUMP=y
CONFIG_SYS_PS_REG_DUMP=y
#@ Enable Default Cmsis Start
CONFIG_DEFAULT_CMSIS_START=n
#@ Enable TFM
CONFIG_TFM=n
#@ support deep sleep
CONFIG_DEEP_PS=n
#@ Enable SPE
CONFIG_SPE=1
#@ Enable pwm
CONFIG_PWM=n
#@ Enable CALENDAR
CONFIG_CALENDAR=n
#@ support mcu sleep
CONFIG_MCU_PS=y
#@ Enable rf power clock
CONFIG_POWER_CLOCK_RF=n
CONFIG_SPE_TEST=y
CONFIG_MPC_TEST=y
CONFIG_PRRO_TEST=y
#@ Enable Interrupt Test
CONFIG_INTERRUPT_TEST=y
#@ Enable Aon Pmu Test
CONFIG_AON_PMU_TEST=y
#@ support cli user configuration header
CONFIG_CLI_USER_CONFIG=n
#@ cli user configuration header directory
CONFIG_CLI_USER_CONFIG_DIR="../../projects/app/config"
CONFIG_SPE_START=n
#@ Enable interrupt statis
CONFIG_ARCH_INT_STATIS=n
#@ Enable I2S
CONFIG_I2S=n
#@ Enable I2S Test
CONFIG_I2S_TEST=n
#@ Enable vendor cal
CONFIG_VND_CAL=y
#@ Write analog register polls sys reg0xb
CONFIG_ANA_REG_WRITE_POLL_REG_B=n
#@ Enable LDO self low power mode
CONFIG_LDO_SELF_LOW_POWER_MODE_ENA=y
#@ Enable CPU0 sub-power dowmain
CONFIG_CPU0_SUB_POWER_DOMAIN_ENA=n
#@ Enable TOUCH
CONFIG_TOUCH=n
#@ Enable touch demos
CONFIG_TOUCH_TEST=n
#@ Enable USB
CONFIG_USB=n
#@ CHERRY_USB
CONFIG_CHERRY_USB=n
#@ Enable USB Device Mode
CONFIG_USB_DEVICE=n
#@ whether Objdump -d elf to lst or not
CONFIG_OBJDUMP=n
#@ enable wifi
CONFIG_WIFI_ENABLE=y
#@ Enable Bluetooth
CONFIG_BLUETOOTH=y
#@ Enable Ble
CONFIG_BLE=y
#@ Enable Bt
CONFIG_BT=y
#@ Enable SDcard power gpio ctrl
CONFIG_SDCARD_POWER_GPIO_CTRL=n
#@ Enable Override Flash Partition
CONFIG_OVERRIDE_FLASH_PARTITION=y
CONFIG_AUD_INTF=y
#@ Enable Audio driver test
CONFIG_AUDIO_TEST=n
#@ Enable media service
CONFIG_MEDIA=y
#@ Support FATFS
CONFIG_FATFS=y
#@ CPU0 RAM size for SPE
CONFIG_CPU0_SPE_RAM_SIZE=0x70000
#@ Enable SBC
CONFIG_SBC=y
CONFIG_A2DP_SINK_DEMO=y
CONFIG_HFP_HF_DEMO=y
#@ Enable AAC decoder lib
CONFIG_AAC_DECODER=y
#@ Enable Audio Record
CONFIG_AUDIO_RECORD=y
#@ Enable Audio Play
CONFIG_AUDIO_PLAY=y
#@ Cpu1 core offset address default 0x2e0000
CONFIG_SYS_CPU1_OFFSET=0x2220000
