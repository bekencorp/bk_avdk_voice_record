#@ Enable Cache
CONFIG_CACHE_ENABLE=n
#@ When this option is enable, more memory will be consumed because
CONFIG_MEM_DEBUG=y
#@ psram aps6408l-o
CONFIG_PSRAM_HEAP_SIZE=0x200000
CONFIG_CPU_WITHOUT_BOOTLOADER=y
CONFIG_AON_MPU_REG_DUMP=y
CONFIG_SYS_PS_REG_DUMP=y
#@ support deep sleep
CONFIG_DEEP_PS=n
#@ Enable pwm
CONFIG_PWM=n
#@ Enable I2S
CONFIG_I2S=n
#@ Enable I2S Test
CONFIG_I2S_TEST=n
#@ Enable TOUCH
CONFIG_TOUCH=n
#@ Enable touch demos
CONFIG_TOUCH_TEST=n
#@ Enable USB
CONFIG_USB=n
#@ CHERRY_USB
CONFIG_CHERRY_USB=n
#@ Enable USB Device Mode
CONFIG_USB_DEVICE=n
#@ enable wifi
CONFIG_WIFI_ENABLE=y
#@ Enable Bluetooth
CONFIG_BLUETOOTH=y
#@ Enable Ble
CONFIG_BLE=y
#@ Enable Bt
CONFIG_BT=y
#@ Enable AAC decoder lib
CONFIG_AAC_DECODER=n
CONFIG_A2DP_SINK_DEMO=n
CONFIG_A2DP_SOURCE_DEMO=y
#@ Enable SDcard auto powerdown when idle
CONFIG_SDCARD_POWER_GPIO_CTRL_AUTO_POWERDOWN_WHEN_IDLE=n
#@ Enable Override Flash Partition
CONFIG_OVERRIDE_FLASH_PARTITION=y
CONFIG_AUD_INTF=n
#@ Enable Audio driver test
CONFIG_AUDIO_TEST=n
#@ Enable Audio
CONFIG_AUDIO=n
#@ Enable audio adc driver
CONFIG_AUDIO_ADC=n
#@ Enable audio dac driver
CONFIG_AUDIO_DAC=n
#@ CPU0 RAM size for SPE
CONFIG_CPU0_SPE_RAM_SIZE=0x70000
#@ Enable Wifi Transfer
CONFIG_WIFI_TRANSFER=n
#@ Enable usb Transfer
CONFIG_USB_TRANSFER=n
#@ enable image save and read image
CONFIG_IMAGE_STORAGE=n
#@ ble ota wait time(ms)
CONFIG_BLE_OTA_WAIT_TIMEOUT=6000
#@ Cpu1 core offset address default 0x2e0000
CONFIG_SYS_CPU1_OFFSET=0x2220000
