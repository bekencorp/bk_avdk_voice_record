#@ Enable Override Flash Partition
CONFIG_OVERRIDE_FLASH_PARTITION=y
#@ Enable Ota Http
CONFIG_OTA_HTTP=y
CONFIG_OTA=y
#@ enable http update ab partition
CONFIG_HTTP_AB_PARTITION=y
#@ enable ota update default partition
CONFIG_OTA_UPDATE_DEFAULT_PARTITION=y
#@ enable ota evade method
CONFIG_OTA_EVADE_METHOD=y
#@ enable ota position independent update
CONFIG_OTA_POSITION_INDEPENDENT_AB=y
#@ cli command code size optimize
CONFIG_CLI_CODE_SIZE_OPTIMIZE_ENABLE=y
#@ Set the threshold of the CS2 TX buffer. The recommended value is 5120 (1024*5).
CONFIG_CS2_TX_BUFFER_THD=262144
#@ Enable PSRAM write through
CONFIG_PSRAM_WRITE_THROUGH=y
#@ CPU0 RAM size for SPE
CONFIG_CPU0_SPE_RAM_SIZE=0X56000
#@ CPU1 app RAM size
CONFIG_CPU1_APP_RAM_SIZE=0X40000
#@ CPU2 app RAM size
CONFIG_CPU2_APP_RAM_SIZE=0XA000
CONFIG_BLUETOOTH_LINK_MAX_COUNT=1
#@ BT reuse media memory at beging of cpu1
CONFIG_BT_REUSE_MEDIA_MEMORY=y
#@ BT reuse media memory size
CONFIG_BT_REUSE_MEDIA_MEM_SIZE=0x1B000
#@ Audio ring buff safe interval
CONFIG_AUD_RING_BUFF_SAFE_INTERVAL=4
#@ Enable Audio
CONFIG_AUDIO=n
#@ Enable audio adc driver
CONFIG_AUDIO_ADC=n
#@ Enable audio dac driver
CONFIG_AUDIO_DAC=n
#@ Enable I2S
CONFIG_I2S=n
#@ 0
CONFIG_DMA_LOGIC_CHAN_ID_MIN=0
#@ The PSRAM used by the media is within 4M.
CONFIG_MEDIA_PSRAM_SIZE_4M=y
#@ The psram address is from 0x60000000 to 0x60800000 for psram aps6408l_o
CONFIG_PSRAM_HEAP_BASE=0x60354000
#@ psram aps6408l-o
CONFIG_PSRAM_HEAP_SIZE=0x7D000
#@ Set psram_malloc base address
CONFIG_PSRAM_HEAP_CPU0_BASE_ADDER=0x60354000
#@ size of psram user need to use
CONFIG_PSRAM_MEM_SLAB_USER_SIZE=0
#@ size of psram audio need to use
CONFIG_PSRAM_MEM_SLAB_AUDIO_SIZE=51200
#@ size of psram encode function need to use
CONFIG_PSRAM_MEM_SLAB_ENCODE_SIZE=946176
#@ size of psram display need to use
CONFIG_PSRAM_MEM_SLAB_DISPLAY_SIZE=2490368
#@ buck disable analog
CONFIG_BUCK_ANALOG_DISABLE=y
#@ Enable Ali Mqtt
CONFIG_ALI_MQTT=n
#@ enable image save and read image
CONFIG_IMAGE_STORAGE=y
#@ Enable Wifi Transfer
CONFIG_WIFI_TRANSFER=y
#@ Enable usb Transfer
CONFIG_USB_TRANSFER=n
#@ Enable media drop strategy
CONFIG_MEDIA_DROP_STRATEGY_ENABLE=y
CONFIG_INTEGRATION_DOORBELL=y
CONFIG_INTEGRATION_DOORBELL_CS2=y
#@ Enable CS2 P2P server lib
CONFIG_CS2_P2P_SERVER=y
#@ Cpu1 core offset address default 0x2e0000
CONFIG_SYS_CPU1_OFFSET=0x2160000
