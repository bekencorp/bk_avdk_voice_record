#@ video data in dtcm
CONFIG_VIDEO_DTCM=y
#@ Enable Media
CONFIG_MEDIA_MINOR=y
#@ Enable media service
CONFIG_MEDIA=y
#@ Enable Cache
CONFIG_CACHE_ENABLE=n
#@ CPU0 RAM size for SPE
CONFIG_CPU0_SPE_RAM_SIZE=0X47000
#@ CPU1 app RAM size
CONFIG_CPU1_APP_RAM_SIZE=0X4B000
#@ CPU2 app RAM size
CONFIG_CPU2_APP_RAM_SIZE=0XE000
#@ Standard dual stream
CONFIG_STANDARD_DUALSTREAM=y
