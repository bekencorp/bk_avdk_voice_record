#@ Enable QSPI
CONFIG_QSPI=y
#@ Enable LCD QSPI
CONFIG_LCD_QSPI=y
#@ Enable LCD_QSPI_ST77903_H0165Y008T API
CONFIG_LCD_QSPI_ST77903_H0165Y008T=y
#@ 2 - RGB565
CONFIG_LCD_QSPI_COLOR_DEPTH_BYTE=2
#@ Enable Lcd scale
CONFIG_MEDIA_PIPELINE=y
#@ Enable Override Flash Partition
CONFIG_OVERRIDE_FLASH_PARTITION=y
