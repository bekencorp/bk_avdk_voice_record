#@ Enable Cache
CONFIG_CACHE_ENABLE=n
#@ Enable Memory Protect Unit Feature
CONFIG_MPU=y
CONFIG_INTEGRATION_DOORBELL=y
#@ Enable LCD_ST7282 API
CONFIG_LCD_ST7282=y
#@ Enable LCD_HX8282 API
CONFIG_LCD_HX8282=y
#@ Enable LCD_ST7796S API
CONFIG_LCD_ST7796S=y
#@ Enable LCD_GC9503V API
CONFIG_LCD_GC9503V=y
#@ Enable LCD_NT35512 API
CONFIG_LCD_NT35512=y
#@ Enable LCD_NT35510 API
CONFIG_LCD_NT35510=y
#@ Enable LCD_NT35510_MCU API
CONFIG_LCD_NT35510_MCU=y
#@ Enable LCD_H050IWV API
CONFIG_LCD_H050IWV=y
#@ Enable LCD_MD0430R API
CONFIG_LCD_MD0430R=y
#@ Enable LCD_MD0700R API
CONFIG_LCD_MD0700R=y
CONFIG_LCD_ST7710S=y
#@ Enable LCD_ST7701S API
CONFIG_LCD_ST7701S=y
#@ Enable LCD_ST7701S_LY API
CONFIG_LCD_ST7701S_LY=y
#@ Enable LCD_ST7789V API
CONFIG_LCD_ST7789V=y
#@ Enable CS2 P2P server lib
CONFIG_CS2_P2P_SERVER=y
CONFIG_INTEGRATION_DOORBELL_CS2=y
#@ Set transfer app task size
CONFIG_TRANS_APP_TASK_SIZE=2048
#@ Enable Override Flash Partition
CONFIG_OVERRIDE_FLASH_PARTITION=y
#@ Enable PSRAM write through
CONFIG_PSRAM_WRITE_THROUGH=y
#@ BT reuse media memory at beging of cpu1
CONFIG_BT_REUSE_MEDIA_MEMORY=y
#@ BT reuse media memory size
CONFIG_BT_REUSE_MEDIA_MEM_SIZE=0x1B000
#@ Audio ring buff safe interval
CONFIG_AUD_RING_BUFF_SAFE_INTERVAL=4
#@ CPU0 RAM size for SPE
CONFIG_CPU0_SPE_RAM_SIZE=0x48000
#@ CPU1 app RAM size
CONFIG_CPU1_APP_RAM_SIZE=0x4D000
#@ CPU2 app RAM size
CONFIG_CPU2_APP_RAM_SIZE=0xB000
#@ Set the threshold of the CS2 TX buffer. The recommended value is 5120 (1024*5).
CONFIG_CS2_TX_BUFFER_THD=262144
#@ use fast connect
CONFIG_WIFI_FAST_CONNECT=n
#@ Enable Iperf Test
CONFIG_IPERF_TEST=n
#@ Enable touch demos
CONFIG_TOUCH_TEST=n
#@ Enable Aon Pmu Test
CONFIG_AON_PMU_TEST=n
#@ Enable Audio driver test
CONFIG_AUDIO_TEST=n
#@ Enable I2S Test
CONFIG_I2S_TEST=n
#@ Enable TOUCH
CONFIG_TOUCH=n
#@ Enable Psram Test
CONFIG_PSRAM_TEST=n
#@ Enable Interrupt Test
CONFIG_INTERRUPT_TEST=n
#@ Cpu1 core offset address default 0x2e0000
CONFIG_SYS_CPU1_OFFSET=0x21b0000
