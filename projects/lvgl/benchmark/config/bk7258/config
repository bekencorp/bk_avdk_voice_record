#@ Enable Cache
CONFIG_CACHE_ENABLE=y
#@ Enable Memory Protect Unit Feature
CONFIG_MPU=y
#@ Enable Override Flash Partition
CONFIG_OVERRIDE_FLASH_PARTITION=y
#@ CPU0 RAM size for SPE
CONFIG_CPU0_SPE_RAM_SIZE=0x36000
#@ CPU1 app RAM size
CONFIG_CPU1_APP_RAM_SIZE=0x4A000
#@ CPU2 app RAM size
CONFIG_CPU2_APP_RAM_SIZE=0x00000
#@ Enable PSRAM write through
CONFIG_PSRAM_WRITE_THROUGH=y
#@ Enable Bluetooth
CONFIG_BLUETOOTH=n
CONFIG_DOORBELL=n
#@ Enable Audio driver test
CONFIG_AUDIO_TEST=n
#@ Enable Ali Mqtt
CONFIG_ALI_MQTT=n
#@ Enable Iperf Test
CONFIG_IPERF_TEST=n
#@ Enable Psram Test
CONFIG_PSRAM_TEST=n
#@ Enable Lv Code load psram
CONFIG_LV_CODE_LOAD_PSRAM=y
#@ Use an external 32k crystal
CONFIG_EXTERN_32K=n
#@ 32k use the 26m divide
CONFIG_LPO_SRC_26M32K=y
#@ MP_A force use the external 32k
CONFIG_LPO_MP_A_FORCE_USE_EXT32K=n
#@ Cpu1 core offset address default 0x2e0000
CONFIG_SYS_CPU1_OFFSET=0x21c0000
